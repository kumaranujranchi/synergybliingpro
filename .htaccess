<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /

    # Serve actual files from root directly (e.g. robots.txt, sw.js, favicons)
    RewriteCond %{REQUEST_FILENAME} -f
    RewriteRule ^ - [L]

    # Serve build assets: /assets/* → public/build/assets/*
    RewriteCond %{DOCUMENT_ROOT}/public/build%{REQUEST_URI} -f
    RewriteRule ^(.*)$ public/build/$1 [L,QSA]

    # Serve other static files from public/ folder
    RewriteCond %{DOCUMENT_ROOT}/public%{REQUEST_URI} -f
    RewriteRule ^(.*)$ public/$1 [L,QSA]

    # All other requests to root index.php (Laravel bootstrap)
    RewriteRule ^ index.php [L]
</IfModule>
